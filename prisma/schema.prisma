generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RubricType {
  TEXTS
  BASICS
  VIDEOS
  TRICKS
}

enum PostSortOption {
  NEWEST
  OLDEST
  SHARE_COUNT
  LIKE_COUNT
  COMMENT_COUNT
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

enum EntitlementSource {
  STRIPE
  MANUAL
}

enum ChatThreadStatus {
  OPEN
  ARCHIVED
  BLOCKED
}

model User {
  id                  String                @id
  name                String
  email               String
  emailVerified       Boolean               @default(false)
  image               String?
  role                String?
  onlineVisibility    Boolean               @default(true)
  pendingDeletionAt   DateTime?
  deleteAfterAt       DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  sessions            Session[]
  accounts            Account[]
  fanWallMessages     FanWallMessage[]
  posts               Post[]
  comments            Comment[]
  postLikes           PostLike[]
  commentLikes        CommentLike[]
  postPreferences     UserPostPreference[]
  stripeCustomer      StripeCustomer?
  subscriptions       Subscription[]
  vipGrants           VipGrant[]
  vipPriceAuditEvents VipPriceAuditEvent[]
  fansGiven           UserFan[]             @relation("fan_source_user")
  fansReceived        UserFan[]             @relation("fan_target_user")
  postShares          PostShare[]
  writeBlocksReceived UserWriteBlock[]      @relation("write_block_target_user")
  writeBlocksCreated  UserWriteBlock[]      @relation("write_block_created_by_user")
  writeBlocksRevoked  UserWriteBlock[]      @relation("write_block_revoked_by_user")
  identityLogs        UserIdentityLog[]
  blockAuditEvents    UserBlockAuditEvent[] @relation("block_audit_performed_by_user")
  chatThreads         ChatThread[]          @relation("chat_thread_user")
  chatMessages        ChatMessage[]         @relation("chat_message_sender")
  blockedChatThreads  ChatThread[]          @relation("chat_thread_blocked_by_user")

  username        String?
  displayUsername String?

  @@unique([email])
  @@unique([username])
  @@index([deleteAfterAt])
  @@map("user")
}

model UserWriteBlock {
  id        String    @id @default(cuid())
  reason    String
  isActive  Boolean   @default(true)
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  scopeCommentCreate Boolean @default(true)
  scopeCommentUpdate Boolean @default(true)
  scopeCommentDelete Boolean @default(true)
  scopeFanwallCreate Boolean @default(true)
  scopeFanwallUpdate Boolean @default(true)
  scopeFanwallDelete Boolean @default(true)

  targetUserId   String?
  targetUser     User?   @relation("write_block_target_user", fields: [targetUserId], references: [id], onDelete: Cascade)
  targetDeviceId String?
  targetIp       String?

  createdByUserId String
  createdByUser   User   @relation("write_block_created_by_user", fields: [createdByUserId], references: [id], onDelete: Cascade)

  revokedByUserId String?
  revokedByUser   User?   @relation("write_block_revoked_by_user", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  auditEvents UserBlockAuditEvent[]

  @@index([isActive, endsAt])
  @@index([targetUserId, isActive])
  @@index([targetDeviceId, isActive])
  @@index([targetIp, isActive])
  @@map("user_write_block")
}

model UserIdentityLog {
  id        String   @id @default(cuid())
  source    String
  createdAt DateTime @default(now())

  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  deviceId  String?
  ipAddress String?

  @@index([userId, createdAt])
  @@index([deviceId, createdAt])
  @@index([ipAddress, createdAt])
  @@map("user_identity_log")
}

model UserBlockAuditEvent {
  id        String   @id @default(cuid())
  eventType String
  reason    String?
  details   Json?
  createdAt DateTime @default(now())

  blockId String?
  block   UserWriteBlock? @relation(fields: [blockId], references: [id], onDelete: SetNull)

  performedByUserId String?
  performedByUser   User?   @relation("block_audit_performed_by_user", fields: [performedByUserId], references: [id], onDelete: SetNull)

  targetUserId   String?
  targetDeviceId String?
  targetIp       String?

  @@index([blockId, createdAt])
  @@index([performedByUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@map("user_block_audit_event")
}

model UserFan {
  id            String    @id @default(cuid())
  isActive      Boolean   @default(true)
  deviceId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  activatedAt   DateTime  @default(now())
  deactivatedAt DateTime?

  targetUserId String
  targetUser   User   @relation("fan_target_user", fields: [targetUserId], references: [id], onDelete: Cascade)

  sourceUserId String?
  sourceUser   User?   @relation("fan_source_user", fields: [sourceUserId], references: [id], onDelete: SetNull)

  @@unique([targetUserId, deviceId])
  @@index([targetUserId, isActive])
  @@index([sourceUserId])
  @@map("user_fan")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model FanWallMessage {
  id        String   @id @default(cuid())
  body      String
  title     String?
  nickname  String?
  contact   String?
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([isPinned, createdAt])
  @@map("fanwall_message")
}

model Post {
  id          String     @id @default(cuid())
  title       String
  content     String? // Rich text content
  type        String // "text" or "media"
  rubric      RubricType
  isPinned    Boolean    @default(false)
  pinnedAt    DateTime?
  vipOnly     Boolean    @default(false)
  published   Boolean    @default(false)
  scheduledAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  media      Media[]
  comments   Comment[]
  likes      PostLike[]
  shares     PostShare[]
  shareCount Int         @default(0)

  @@index([authorId])
  @@index([rubric])
  @@index([published, createdAt])
  @@index([rubric, published, vipOnly, createdAt])
  @@index([rubric, isPinned, pinnedAt])
  @@map("post")
}

model PostShare {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([postId, createdAt])
  @@map("post_share")
}

model StripeCustomer {
  id               String         @id @default(cuid())
  stripeCustomerId String         @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  userId           String         @unique
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions    Subscription[]

  @@index([userId])
  @@map("stripe_customer")
}

model Subscription {
  id                   String             @id @default(cuid())
  stripeSubscriptionId String             @unique
  status               SubscriptionStatus
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  endedAt              DateTime?
  priceId              String?
  currency             String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeCustomerId String?
  customer         StripeCustomer? @relation(fields: [stripeCustomerId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([stripeCustomerId])
  @@index([currentPeriodEnd])
  @@map("subscription")
}

model VipGrant {
  id              String            @id @default(cuid())
  source          EntitlementSource @default(MANUAL)
  startsAt        DateTime          @default(now())
  endsAt          DateTime?
  revokedAt       DateTime?
  note            String?
  createdByUserId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startsAt])
  @@index([userId, endsAt])
  @@index([userId, revokedAt])
  @@map("vip_grant")
}

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  payload       Json?
  processedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([type])
  @@map("stripe_webhook_event")
}

model VipPrice {
  id        String   @id @default(cuid())
  currency  String   @unique
  priceId   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@map("vip_price")
}

model VipPriceAuditEvent {
  id               String   @id @default(cuid())
  currency         String
  previousPriceId  String?
  nextPriceId      String?
  previousIsActive Boolean?
  nextIsActive     Boolean
  changedByUserId  String?
  createdAt        DateTime @default(now())

  changedByUser User? @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([currency, createdAt])
  @@index([changedByUserId])
  @@map("vip_price_audit_event")
}

model Media {
  id         String   @id @default(cuid())
  url        String
  type       String // "image" or "video"
  fileName   String
  fileSize   Int
  uploadedAt DateTime @default(now())

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("media")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  nickname String?

  likes CommentLike[]

  @@index([postId])
  @@index([userId])
  @@map("comment")
}

model PostLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId])
  @@map("post_like")
}

model CommentLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
  @@index([userId])
  @@map("comment_like")
}

model SiteSetting {
  id        String   @id @default("global")
  mainTitle String   @default("The real basketball is out there")
  mainBio   String   @default("Basketball player, Creator, Visionair From Prague, Czech Republic..")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_setting")
}

model UserPostPreference {
  id           String         @id @default(cuid())
  rubric       RubricType
  postsPerPage Int            @default(10)
  sortBy       PostSortOption @default(NEWEST)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, rubric])
  @@index([userId])
  @@map("user_post_preference")
}

model ChatThread {
  id             String           @id @default(cuid())
  status         ChatThreadStatus @default(OPEN)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  lastMessageAt  DateTime?
  archivedAt     DateTime?
  blockedAt      DateTime?
  unreadForUser  Int              @default(0)
  unreadForAdmin Int              @default(0)

  userId String
  user   User   @relation("chat_thread_user", fields: [userId], references: [id], onDelete: Cascade)

  blockedByUserId String?
  blockedByUser   User?   @relation("chat_thread_blocked_by_user", fields: [blockedByUserId], references: [id], onDelete: SetNull)

  messages ChatMessage[]

  @@unique([userId])
  @@index([status, updatedAt])
  @@index([lastMessageAt])
  @@map("chat_thread")
}

model ChatMessage {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  threadId String
  thread   ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  senderUserId String
  senderUser   User   @relation("chat_message_sender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([senderUserId, createdAt])
  @@map("chat_message")
}
